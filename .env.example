# Token ESIOS (gratuito en https://api.esios.ree.es/)
ESIOS_TOKEN=pon_aqui_tu_token_esios

# Token AEMET (gratuito en https://opendata.aemet.es/centrodedescargas/altaUsuario)
AEMET_TOKEN=pon_aqui_tu_token_aemet

# Código de municipio AEMET (08019 = Barcelona, 28079 = Madrid, 46250 = Valencia)
AEMET_MUNICIPIO=08019

# URL de Prometheus en la red interna (para el acumulado real)
PROMETHEUS_URL=http://observatorio-prometheus:9090
